{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/contracts/governance/decision.v2.schema.json",
  "title": "decision.v2",
  "type": "object",
  "required": [
    "schema_version",
    "contract_version",
    "decision_id",
    "idempotency_key",
    "author",
    "evidence_refs",
    "command_id",
    "challenge",
    "occurred_at",
    "payload_digest",
    "status",
    "side_effect_class",
    "explicit_human_approval"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2.0"
    },
    "contract_version": {
      "type": "string",
      "const": "v2"
    },
    "decision_id": {
      "type": "string",
      "minLength": 1
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "author": {
      "type": "string",
      "minLength": 1
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "command_id": {
      "type": "string",
      "minLength": 1
    },
    "challenge": {
      "type": "object",
      "required": [
        "challenge_id",
        "status",
        "expires_at"
      ],
      "properties": {
        "challenge_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "NOT_REQUIRED",
            "PENDING",
            "VALIDATED",
            "EXPIRED",
            "INVALIDATED"
          ]
        },
        "expires_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "payload_digest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "status": {
      "type": "string",
      "enum": [
        "PENDING",
        "APPROVED",
        "REJECTED",
        "KILLED",
        "EXPIRED"
      ]
    },
    "side_effect_class": {
      "type": "string",
      "enum": [
        "none",
        "operational",
        "financial"
      ]
    },
    "explicit_human_approval": {
      "type": "boolean"
    }
  },
  "additionalProperties": true
}
