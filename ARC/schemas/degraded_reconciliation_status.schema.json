{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/schemas/degraded_reconciliation_status.schema.json",
  "title": "degraded_reconciliation_status",
  "type": "object",
  "required": [
    "schema_version",
    "incident_id",
    "status",
    "reconciled_at",
    "promotion_blocked",
    "evidence_ref"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "incident_id": {
      "type": "string",
      "minLength": 2
    },
    "status": {
      "type": "string",
      "enum": ["pending", "reconciled", "failed"]
    },
    "reconciled_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "promotion_blocked": {
      "type": "boolean"
    },
    "evidence_ref": {
      "type": "string",
      "minLength": 2
    }
  },
  "additionalProperties": false
}
