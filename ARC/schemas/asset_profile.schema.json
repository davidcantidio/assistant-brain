{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/schemas/asset_profile.schema.json",
  "title": "asset_profile",
  "type": "object",
  "required": [
    "schema_version",
    "contract_version",
    "asset_class",
    "profile_version",
    "market_calendar",
    "market_sessions",
    "order_constraints",
    "rounding_rules",
    "cost_model",
    "liquidity_controls",
    "risk_units",
    "capital_ramp_defaults"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "contract_version": {
      "type": "string",
      "const": "v1"
    },
    "asset_class": {
      "type": "string",
      "enum": ["crypto_spot", "equities_br", "fii_br", "fixed_income_br"]
    },
    "profile_version": {
      "type": "string",
      "minLength": 1
    },
    "market_calendar": {
      "type": "string",
      "minLength": 1
    },
    "market_sessions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["label", "timezone", "opens_at", "closes_at"],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1
          },
          "timezone": {
            "type": "string",
            "minLength": 1
          },
          "opens_at": {
            "type": "string",
            "pattern": "^[0-2][0-9]:[0-5][0-9]$"
          },
          "closes_at": {
            "type": "string",
            "pattern": "^[0-2][0-9]:[0-5][0-9]$"
          }
        },
        "additionalProperties": false
      }
    },
    "order_constraints": {
      "type": "object",
      "required": ["min_notional", "lot_size", "tick_size"],
      "properties": {
        "min_notional": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "lot_size": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "tick_size": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      },
      "additionalProperties": false
    },
    "rounding_rules": {
      "type": "object",
      "required": ["quantity_mode", "price_mode"],
      "properties": {
        "quantity_mode": {
          "type": "string",
          "minLength": 1
        },
        "price_mode": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "cost_model": {
      "type": "object",
      "required": ["base_fee_bps", "emoluments_bps", "taxes_bps", "slippage_bps"],
      "properties": {
        "base_fee_bps": {
          "type": "number",
          "minimum": 0
        },
        "emoluments_bps": {
          "type": "number",
          "minimum": 0
        },
        "taxes_bps": {
          "type": "number",
          "minimum": 0
        },
        "slippage_bps": {
          "type": "number",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "liquidity_controls": {
      "type": "object",
      "required": ["max_spread_bps", "min_average_daily_volume_brl"],
      "properties": {
        "max_spread_bps": {
          "type": "number",
          "minimum": 0
        },
        "min_average_daily_volume_brl": {
          "type": "number",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "risk_units": {
      "type": "object",
      "required": ["quote_currency", "quantity_unit"],
      "properties": {
        "quote_currency": {
          "type": "string",
          "minLength": 1
        },
        "quantity_unit": {
          "type": "string",
          "minLength": 1
        },
        "max_loss_per_unit_brl": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      },
      "additionalProperties": false
    },
    "capital_ramp_defaults": {
      "type": "object",
      "required": ["L0"],
      "properties": {
        "L0": {
          "type": "object",
          "required": [
            "max_notional_per_order",
            "max_daily_notional",
            "max_orders_per_day"
          ],
          "properties": {
            "max_notional_per_order": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "max_daily_notional": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "max_orders_per_day": {
              "type": "integer",
              "minimum": 1
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "asset_class": {
            "const": "fixed_income_br"
          }
        },
        "required": ["asset_class"]
      },
      "then": {
        "properties": {
          "risk_units": {
            "required": ["quote_currency", "quantity_unit", "max_loss_per_unit_brl"]
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
