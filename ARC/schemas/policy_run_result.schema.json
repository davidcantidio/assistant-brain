{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://assistant-brain.local/schemas/policy_run_result.schema.json",
  "title": "PolicyRunResult",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "status",
    "domain",
    "total_rules",
    "passed_rules",
    "failed_rules",
    "violations",
    "rule_results",
    "metrics"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "2.0"
      ]
    },
    "run_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "PASS",
        "FAIL"
      ]
    },
    "domain": {
      "type": "string",
      "enum": [
        "runtime",
        "security",
        "governance",
        "trading",
        "all"
      ]
    },
    "total_rules": {
      "type": "integer",
      "minimum": 0
    },
    "passed_rules": {
      "type": "integer",
      "minimum": 0
    },
    "failed_rules": {
      "type": "integer",
      "minimum": 0
    },
    "violations": {
      "type": "array",
      "items": {
        "$ref": "./rule_violation.schema.json"
      }
    },
    "rule_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "rule_id",
          "status",
          "severity",
          "runtime_ms",
          "error_code"
        ],
        "properties": {
          "rule_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "PASS",
              "FAIL"
            ]
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "runtime_ms": {
            "type": "integer",
            "minimum": 0
          },
          "error_code": {
            "type": [
              "string",
              "null"
            ]
          },
          "category": {
            "type": [
              "string",
              "null"
            ]
          },
          "evidence_ref": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "metrics": {
      "type": "object",
      "required": [
        "pass_rate",
        "contradiction_count",
        "rule_runtime_ms_total"
      ],
      "properties": {
        "pass_rate": {
          "type": "number",
          "minimum": 0
        },
        "contradiction_count": {
          "type": "integer",
          "minimum": 0
        },
        "rule_runtime_ms_total": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
